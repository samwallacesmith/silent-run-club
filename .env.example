# Production site URL (no trailing slash). In Vercel: Project → Settings → Environment Variables
# as NUXT_PUBLIC_SITE_URL for Production (and Preview if you want correct OG URLs on previews).
NUXT_PUBLIC_SITE_URL=https://silentrunnersclub.com

# Optional: default QR when an event has no jamUrl
# NUXT_PUBLIC_DEFAULT_JAM_QR_URL=
