# Production site URL (no trailing slash). In Vercel: Project → Settings → Environment Variables
# as NUXT_PUBLIC_SITE_URL for Production (and Preview if you want correct OG URLs on previews).
NUXT_PUBLIC_SITE_URL=https://silentrunnersclub.com

# Listen QR: the app ships with a baked-in Spotify URL in nuxt.config (clubListenQrUrl).
# Optional: set this to override that default without changing code (e.g. new jam/session link).
# NUXT_PUBLIC_PERSISTENT_JAM_QR_URL=

# Optional: used only when persistent jam URL is empty — default QR if an event has no jamUrl
# NUXT_PUBLIC_DEFAULT_JAM_QR_URL=
